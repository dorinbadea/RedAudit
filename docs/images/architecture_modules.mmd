flowchart LR

  %% ──────────────────────────────────────────────
  %% RedAudit architecture (functional view with module mapping)
  %% Goal: match the System Overview PNG structure while keeping module-level traceability.
  %% Render to SVG:
  %%   npx -p @mermaid-js/mermaid-cli mmdc -i docs/images/architecture_modules.mmd -o docs/images/architecture_modules.svg
  %% ──────────────────────────────────────────────

  classDef entry fill:#E7F3FF,stroke:#0969DA,stroke-width:1px,color:#0B0F14;
  classDef orch fill:#111827,stroke:#0B0F14,stroke-width:1px,color:#FFFFFF;
  classDef scan fill:#FDE7E7,stroke:#CF222E,stroke-width:1px,color:#0B0F14;
  classDef analysis fill:#FFF3D6,stroke:#9A6700,stroke-width:1px,color:#0B0F14;
  classDef report fill:#EAF9EA,stroke:#1A7F37,stroke-width:1px,color:#0B0F14;
  classDef aux fill:#EEF2FF,stroke:#4F46E5,stroke-width:1px,color:#0B0F14;
  classDef io fill:#F6F8FA,stroke:#57606A,stroke-width:1px,color:#0B0F14;
  classDef ext fill:#FFFFFF,stroke:#D0D7DE,stroke-width:1px,stroke-dasharray: 3 3,color:#0B0F14;

  %% ──────────────────────────────────────────────
  %% Update & entry
  %% ──────────────────────────────────────────────
  subgraph ENTRY["Update & Entry"]
    direction TB
    user_cli["User / CLI (Wizard)\n`redaudit/cli.py`"]:::orch
    updater["Updater Module\n`redaudit/core/updater.py`"]:::orch
    entrypoints["Launch scripts (wrappers)\n`/usr/local/bin/redaudit`, `python -m redaudit`, `redaudit.py`"]:::entry
  end

  updater <--> |checks / prompts| user_cli
  user_cli <--> |feedback / updates| updater
  entrypoints --> user_cli

  %% ──────────────────────────────────────────────
  %% Orchestrator
  %% ──────────────────────────────────────────────
  orchestrator["Orchestrator (Scan Controller)\n`redaudit/core/auditor.py`"]:::orch
  user_cli <--> orchestrator

  %% ──────────────────────────────────────────────
  %% Scanning & enumeration (left block in PNG)
  %% ──────────────────────────────────────────────
  subgraph SCANNING["Scanning & Enumeration"]
    direction TB
    prescan["Pre-scan (async TCP connect)\n`redaudit/core/prescan.py`"]:::scan
    net_detect["Network Detection (IPv4/IPv6)\n`redaudit/core/network.py`"]:::scan

    subgraph SCANNER_ENGINE["Scanner Engine (Nmap + capture)\n`redaudit/core/scanner.py`"]
      direction TB
      nmap_engine["Nmap engine\n(scan + OS detection)"]:::scan
      proxy_wrap["Proxy wrapper (optional)\n`redaudit/core/proxy.py`"]:::scan
      udp_timing["UDP timing / probe\n`redaudit/core/udp_probe.py`"]:::scan
      pcap_capture["PCAP micro-capture (best-effort)\n(scanner.py)"]:::scan
    end
  end

  %% ──────────────────────────────────────────────
  %% Discovery & topology (center below orchestrator in PNG)
  %% ──────────────────────────────────────────────
  subgraph DISCOVERY["Discovery & Topology"]
    direction TB
    net_discovery["Network Discovery\n(protocol/L2 discovery + opt-in redteam)\n`redaudit/core/net_discovery.py`"]:::scan
    hyperscan["Active L2 / ARP discovery (optional)\n`redaudit/core/hyperscan.py`"]:::scan
    topology["Topology mapping (optional)\n`redaudit/core/topology.py`"]:::scan
  end

  %% ──────────────────────────────────────────────
  %% Analysis (center block in PNG)
  %% ──────────────────────────────────────────────
  subgraph ANALYSIS["Analysis"]
    direction TB
    vuln_scans["Vulnerability scanners\n(Nikto, testssl.sh)\n`redaudit/core/scanner.py`"]:::analysis
    smart_checks["Smart-check + fingerprints\n(magic bytes / heuristics)\n`redaudit/core/scanner.py`"]:::analysis
    http_enrich["HTTP enrichment\n(headers, redirects, metadata)\n`redaudit/core/scanner.py`"]:::analysis
    tls_analysis["SSL/TLS deep analysis\n`redaudit/core/scanner.py`"]:::analysis
    exploit_lookup["Exploit lookup\n(searchsploit)\n`redaudit/core/scanner.py`"]:::analysis
    cve_corr["CVE correlation (NVD)\n`redaudit/core/nvd.py`"]:::analysis
    fp_filter["False-positive filter / hygiene\n`redaudit/core/verify_vuln.py`"]:::analysis
  end

  %% ──────────────────────────────────────────────
  %% Reporting & output (right block in PNG)
  %% ──────────────────────────────────────────────
  subgraph OUTPUT["Reporting & Output"]
    direction TB
    entity["Entity resolution\n(unify multi-interface assets)\n`redaudit/core/entity_resolver.py`"]:::report
    siem["SIEM formatter (ECS/CEF)\n`redaudit/core/siem.py`"]:::report
    reporter["Reporter (JSON/TXT)\n`redaudit/core/reporter.py`"]:::report
    encryption["Encryption (AES)\n`redaudit/core/crypto.py`"]:::report

    subgraph EXPORTS["Exports (encryption disabled)"]
      direction TB
      html["HTML dashboard\n`redaudit/core/html_reporter.py`"]:::report
      jsonl["JSONL exports\n`redaudit/core/jsonl_exporter.py`"]:::report
      playbooks["Remediation playbooks\n`redaudit/core/playbook_generator.py`"]:::report
    end
  end

  %% ──────────────────────────────────────────────
  %% Auxiliary / shared services (right dotted aux in PNG)
  %% ──────────────────────────────────────────────
  subgraph AUX["Auxiliary & Shared Services"]
    direction TB
    cmd["Command execution layer\n(dry-run aware)\n`redaudit/core/command_runner.py`"]:::aux
    dryrun["Dry-run policy\n`redaudit/utils/dry_run.py`"]:::aux
    power["Sleep inhibition (best-effort)\n`redaudit/core/power.py`"]:::aux
    cfg["Persisted defaults\n`redaudit/utils/config.py`"]:::aux
    i18n["i18n translations\n`redaudit/utils/i18n.py`"]:::aux
    paths["Paths & sudo-safe HOME\n`redaudit/utils/paths.py`"]:::aux
    constants["Version & constants\n`redaudit/utils/constants.py`"]:::aux
    diff["Report diff / compare\n`redaudit/core/diff.py`"]:::aux
  end

  %% ──────────────────────────────────────────────
  %% External boundaries
  %% ──────────────────────────────────────────────
  ext_tools["External tools\n(nmap, tcpdump, nikto, testssl.sh, searchsploit, ...)\n(shell=false)"]:::ext
  targets["Target network\n(hosts/services)"]:::ext
  nvd_api["NVD API"]:::ext
  exploitdb["ExploitDB / searchsploit DB"]:::ext

  artifacts["Reports folder\n(JSON/TXT/HTML/JSONL/PCAP/Playbooks)"]:::io
  filesystem["Filesystem\n(ownership/permissions)"]:::io

  %% ──────────────────────────────────────────────
  %% Control flow (two-way where results flow back)
  %% ──────────────────────────────────────────────
  orchestrator <--> prescan
  orchestrator <--> net_detect
  orchestrator <--> nmap_engine
  orchestrator <--> pcap_capture
  orchestrator -. "--net-discovery | full mode" .-> net_discovery
  orchestrator -. "user accepts prompt" .-> topology
  net_discovery -. "active L2 (opt-in)" .-> hyperscan

  %% Service data and analysis flow
  nmap_engine <--> vuln_scans
  nmap_engine <--> smart_checks
  vuln_scans <--> fp_filter
  http_enrich <--> fp_filter
  tls_analysis <--> fp_filter
  smart_checks <--> fp_filter

  nmap_engine <--> http_enrich
  nmap_engine <--> tls_analysis
  nmap_engine <--> exploit_lookup
  nmap_engine <--> cve_corr

  %% Reporting flow
  fp_filter <--> entity
  entity <--> siem
  siem <--> reporter
  reporter <--> encryption
  reporter <--> html
  reporter <--> jsonl
  reporter <--> playbooks

  %% Dotted aux (shared services)
  user_cli <-.-> cfg
  user_cli <-.-> i18n
  user_cli <-.-> constants
  orchestrator <-.-> cfg
  orchestrator <-.-> paths
  orchestrator <-.-> power
  orchestrator <-.-> dryrun
  orchestrator <-.-> cmd
  reporter <-.-> paths
  reporter <-.-> cmd
  user_cli -. "compare reports" .-> diff

  %% External interactions (request/response)
  cmd <--> ext_tools
  nmap_engine <--> targets
  net_discovery <--> targets
  cve_corr <--> nvd_api
  exploit_lookup <--> exploitdb

  %% Artifacts
  reporter --> artifacts
  artifacts <--> filesystem
  paths <--> filesystem
